# Quick Count — standalone configuration.
# Copy to .env for local/standalone runs. Inside Usernode the platform injects
# DATABASE_URL / JWT_SECRET / PORT / USERNODE_ENV automatically.

# Port the server listens on (platform always uses 3000).
PORT=3000

# Postgres connection string. Optional: if unset, the transaction log is kept
# in memory only (fine for local-dev / ephemeral runs).
DATABASE_URL=postgres://quickcount:quickcount@localhost:5432/quickcount

# Environment marker. Use "staging" to seed obviously-fake demo data.
USERNODE_ENV=production

# Usernode node the indexer polls for on-chain transactions. Leave empty in
# local-dev (the in-process mock ledger is used instead).
NODE_RPC_URL=

# Treasury address that receives organization registration fees.
TREASURY_ADDR=ut1treasuryquickcount00000000000000000000

# Minimum registration fee (smallest on-chain unit) an org must pay to go live.
ORG_FEE=100

# Comma-separated platform-admin wallet addresses (fee waivers, admin view).
ADMIN_ADDRS=

# Set to "local-dev" (or pass --local-dev) to run fully offline with /__mock/*.
# In this mode the server also serves GET /__mock/enabled (200) — the endpoint
# the hosted wallet bridge probes to enter mock mode; without it the bridge
# fails transactions with "Mock API not enabled".
APP_MODE=
