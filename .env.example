# Quick Count — standalone configuration.
# Copy to .env for local/standalone runs. Inside Usernode the platform injects
# DATABASE_URL / JWT_SECRET / PORT / USERNODE_ENV automatically.

# Port the server listens on (platform always uses 3000).
PORT=3000

# Postgres connection string. Optional: if unset, the transaction log is kept
# in memory only (fine for local-dev / ephemeral runs).
DATABASE_URL=postgres://quickcount:quickcount@localhost:5432/quickcount

# Environment marker. Use "staging" to seed obviously-fake demo data.
USERNODE_ENV=production

# Public block explorer base URL — the CANONICAL chain read source. The indexer
# reads <EXPLORER_API_URL>/<CHAIN_ID>/transactions; the browser polls the same
# explorer through the relative, auth-exempt /explorer-api/ prefix to confirm
# transactions. Leave empty to fall back to NODE_RPC_URL (standalone deploys).
EXPLORER_API_URL=

# Chain id segment used when addressing the explorer (…/<CHAIN_ID>/transactions).
CHAIN_ID=usernode

# Usernode node the indexer polls for on-chain transactions. FALLBACK only —
# used when EXPLORER_API_URL is unset. Inside the platform this is injected with
# the real in-network node URL; for standalone deploys point it at your node so
# the indexer has a chain read source (otherwise registrations broadcast but are
# never read back). Leave empty in local-dev (the in-process mock ledger is used
# instead). dapp.json carries a default of http://usernode-node:3000.
NODE_RPC_URL=

# Treasury address that receives organization registration fees.
TREASURY_ADDR=ut1treasuryquickcount00000000000000000000

# Minimum registration fee (smallest on-chain unit) an org must pay to go live.
ORG_FEE=100

# Comma-separated platform-admin wallet addresses (fee waivers, admin view).
ADMIN_ADDRS=

# Set to "local-dev" (or pass --local-dev) to run fully offline with /__mock/*.
# In this mode the server also serves GET /__mock/enabled (200) — the endpoint
# the hosted wallet bridge probes to enter mock mode; without it the bridge
# fails transactions with "Mock API not enabled".
APP_MODE=

# Self-contained local-ingest ("mock ledger") switch. Default "false" → REAL
# on-chain mode: the hosted bridge signs/broadcasts and the indexer reads
# transactions back from EXPLORER_API_URL / NODE_RPC_URL. Set "true" to record
# submissions straight into the event log with no chain (local-dev and the
# staging preview run with it on). dapp.json carries default "false" with a
# staging_default of "true".
MOCK_TX_FLOW=

# The application's own on-chain wallet PUBLIC address (ut1…). Public identifier.
# dapp.json ships an obviously-fake placeholder so the deploy never blocks; set
# the real address in Settings → Secrets before relying on app-signed operations.
APP_PUBKEY=

# The application's on-chain wallet SIGNING key (secret — private in dapp.json,
# encrypted at rest, isolated from staging). No server-side signing path uses it
# yet; declared so you can store the real key now. NEVER commit a real value.
APP_SECRET_KEY=

# Cadence (ms) for the background chain poll and the client auto-refresh.
# Defaults to 6000; values below 1000 are floored to 1000. Local-dev keeps a
# fixed snappy 2000ms loop regardless of this value.
TIMER_DURATION_MS=6000
