{
  "name": "Quick Count",
  "secrets": [
    {
      "key": "NODE_RPC_URL",
      "description": "Usernode node RPC base URL for indexer polling. Platform-managed in-network; optional for standalone deploys.",
      "required": false,
      "private": false
    },
    {
      "key": "APP_PUBKEY",
      "description": "Platform wallet address. org_register transactions must pay 1,000 tokens to this address.",
      "required": false,
      "private": false,
      "default": ""
    },
    {
      "key": "LOCAL_DEV",
      "description": "Set to false in production to enable live chain calls. Default true stubs all blockchain operations.",
      "required": false,
      "private": false,
      "default": "true"
    }
  ],
  "tests": [
    {
      "name": "Dashboard loads with app name",
      "path": "/",
      "expectText": "Quick Count"
    },
    {
      "name": "Elections list renders",
      "path": "/#elections",
      "expectSelector": "#screen-elections"
    },
    {
      "name": "Organizations screen renders",
      "path": "/#orgs",
      "expectSelector": "#screen-orgs"
    },
    {
      "name": "Staging election visible on dashboard",
      "path": "/",
      "expectText": "Staging Demo General Election"
    },
    {
      "name": "Demo election shows latest-submission tally",
      "path": "/dashboard.html?eid=demo-election",
      "expectText": "stations reported"
    },
    {
      "name": "Seeded candidate avatar serves an image",
      "path": "/api/public/elections/demo-election/attachments/cand_avatar/1"
    }
  ]
}
