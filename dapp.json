{
  "name": "Quick Count",
  "secrets": [
    {
      "key": "APP_PUBKEY",
      "description": "The application's receiving wallet address on the Usernode blockchain network. All vote submission transactions are sent to this address.",
      "required": true,
      "private": false,
      "default": "ut1placeholder000000000000000000000000000000000000000"
    },
    {
      "key": "LOCAL_DEV",
      "description": "Set to true to enable local dev mode — skips all blockchain and file I/O calls, returns fake data",
      "required": false,
      "private": false,
      "default": "true"
    },
    {
      "key": "NODE_RPC_URL",
      "description": "Base URL of the Usernode node the indexer polls for on-chain transactions. Platform-managed in-network; optional for standalone deploys (the indexer no-ops when unset).",
      "required": false,
      "private": false
    }
  ],
  "tests": [
    { "name": "App shell loads", "path": "/", "expectSelector": "h1" },
    { "name": "Dashboard renders", "path": "/", "expectSelector": "#dashboard" },
    { "name": "Stations table renders", "path": "/", "expectSelector": "#stations-table" },
    { "name": "Explorer renders", "path": "/explorer", "expectSelector": "#tx-list" },
    {
      "name": "Live dashboard renders demo election",
      "path": "/dashboard.html",
      "expectText": "Staging demo"
    },
    {
      "name": "Demo election shows latest-submission tally",
      "path": "/dashboard.html?eid=demo-election",
      "expectText": "stations reported"
    }
  ]
}
